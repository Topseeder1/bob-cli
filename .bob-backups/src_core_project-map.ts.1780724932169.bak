import * as fs from 'fs/promises';
import * as path from 'path';
import * as os from 'os';
import * as crypto from 'crypto';

const BOB_DIR = path.join(os.homedir(), '.bob');
const PROJECTS_DIR = path.join(BOB_DIR, 'projects');

export interface ProjectMeta {
  name: string;
  path: string;
  createdAt: string;
  lastIndexed: string | null;
}

export interface TaskFile {
  filePath: string;
  status: boolean;
  summary: string | null;
  dependencies: string[];
  error: string | null;
}

/**
 * Derives a project name from the working directory.
 */
export function getProjectName(workingDir: string): string {
  return path.basename(workingDir);
}

/**
 * Returns the full path to the project's .bob folder.
 */
export function getProjectDir(workingDir: string): string {
  const name = getProjectName(workingDir);
  return path.join(PROJECTS_DIR, name);
}

/**
 * Ensures the project folder structure exists.
 * @returns {Promise<{projectDir: string; conversationsDir: string; analysisDir: string; runsDir: string}>}
 */
export async function ensureProjectStructure(workingDir: string): Promise<{
  projectDir: string;
  conversationsDir: string;
  analysisDir: string;
  runsDir: string;
}> {
  const projectDir = getProjectDir(workingDir);
  const conversationsDir = path.join(projectDir, 'conversations');
  const analysisDir = path.join(projectDir, 'analysis');
  const runsDir = path.join(analysisDir, 'runs');

  for (const dir of [BOB_DIR, PROJECTS_DIR, projectDir, conversationsDir, analysisDir, runsDir]) {
    await fs.mkdir(dir, { recursive: true });
  }

  // Create project.json if it doesn't exist
  const metaPath = path.join(projectDir, 'project.json');
  try {
    await fs.access(metaPath);
  } catch (error) {
    // File does not exist, proceed to create
  }
  
  // Check existence again using access to properly handle the async flow
  try {
      await fs.access(metaPath);
  } catch (error) {
      // File does not exist, proceed to create
  }


  const meta: ProjectMeta = {
    name: getProjectName(workingDir),
    path: workingDir,
    createdAt: new Date().toISOString(),
    lastIndexed: null,
  };
  await fs.writeFile(metaPath, JSON.stringify(meta, null, 2));

  return { projectDir, conversationsDir, analysisDir, runsDir };
}

/**
 * Creates a new analysis run with task files for each source file.
 * @returns {Promise<{runId: string; runDir: string; tasksDir: string}>}
 */
export async function createAnalysisRun(workingDir: string, files: string[]): Promise<{
  runId: string;
  runDir: string;
  tasksDir: string;
}> {
  const { runsDir } = await ensureProjectStructure(workingDir);
  const runId = new Date().toISOString().replace(/[:.]/g, '-');
  const runDir = path.join(runsDir, runId);
  const tasksDir = path.join(runDir, 'tasks');

  await fs.mkdir(runDir, { recursive: true });
  await fs.mkdir(tasksDir, { recursive: true });

  // Create manifest
  const manifest = {
    runId,
    status: 'in_progress',
    totalFiles: files.length,
    completedFiles: 0,
    createdAt: new Date().toISOString(),
    projectPath: workingDir,
  };
  await fs.writeFile(path.join(runDir, 'manifest.json'), JSON.stringify(manifest, null, 2));

  // Create task files
  const taskPromises: Promise<void>[] = [];
  for (const filePath of files) {
    const taskId = filePath.replace(/[\/\\]/g, '_');
    const task: TaskFile = {
      filePath,
      status: false,
      summary: null,
      dependencies: [],
      error: null,
    };
    taskPromises.push(fs.writeFile(path.join(tasksDir, `${taskId}.json`), JSON.stringify(task, null, 2)));
  }
  await Promise.all(taskPromises);

  return { runId, runDir, tasksDir };
}

/**
 * Marks a task as complete with summary.
 * @param tasksDir The directory containing task JSON files.
 * @param filePath The path of the file corresponding to the task.
 * @param summary The summary to write.
 */
export async function completeTask(tasksDir: string, filePath: string, summary: string): Promise<void> {
  const taskId = filePath.replace(/[\/\\]/g, '_');
  const taskPath = path.join(tasksDir, `${taskId}.json`);

  try {
    await fs.access(taskPath);
    const content = await fs.readFile(taskPath, 'utf-8');
    const task: TaskFile = JSON.parse(content);
    task.status = true;
    task.summary = summary;
    await fs.writeFile(taskPath, JSON.stringify(task, null, 2));
  } catch (e) {
    // File not found or other error, ignore
  }
}

/**
 * Updates the manifest progress count.
 * @param runDir The directory containing the manifest.
 * @param completedFiles The count of completed tasks.
 * @param status Optional new status for the manifest.
 */
export async function updateManifestProgress(runDir: string, completedFiles: number, status?: string): Promise<void> {
  const manifestPath = path.join(runDir, 'manifest.json');
  try {
    await fs.access(manifestPath);
    const content = await fs.readFile(manifestPath, 'utf-8');
    const manifest = JSON.parse(content);
    manifest.completedFiles = completedFiles;
    if (status) manifest.status = status;
    await fs.writeFile(manifestPath, JSON.stringify(manifest, null, 2));
  } catch (e) {
    // Manifest not found, ignore
  }
}

/**
 * Saves the final summaries.json for the project.
 * @param workingDir The working directory of the project.
 * @param summaries Map of file paths to summaries.
 * @returns {Promise<void>}
 */
export async function saveSummaries(workingDir: string, summaries: Record<string, string>): Promise<void> {
  const { analysisDir } = await ensureProjectStructure(workingDir);
  await fs.writeFile(path.join(analysisDir, 'summaries.json'), JSON.stringify(summaries, null, 2));

  // Update project meta
  const projectDir = getProjectDir(workingDir);
  const metaPath = path.join(projectDir, 'project.json');
  try {
    await fs.access(metaPath);
    const content = await fs.readFile(metaPath, 'utf-8');
    const meta: ProjectMeta = JSON.parse(content);
    meta.lastIndexed = new Date().toISOString();
    await fs.writeFile(metaPath, JSON.stringify(meta, null, 2));
  } catch (e) {
    // Project meta file not found, ignore update
  }
}

/**
 * Saves the final dependencies.json for the project.
 * @param workingDir The working directory of the project.
 * @param dependencies Map of file paths to dependency arrays.
 * @returns {Promise<void>}
 */
export async function saveDependencies(workingDir: string, dependencies: Record<string, string[]>): Promise<void> {
  const { analysisDir } = await ensureProjectStructure(workingDir);
  await fs.writeFile(path.join(analysisDir, 'dependencies.json'), JSON.stringify(dependencies, null, 2));
}

/**
 * Loads summaries for the current project. Returns null if not indexed.
 * @param workingDir The working directory of the project.
 * @returns {Promise<Record<string, string> | null>}
 */
export async function loadSummaries(workingDir: string): Promise<Record<string, string> | null> {
  const { analysisDir } = await ensureProjectStructure(workingDir);
  const summariesPath = path.join(analysisDir, 'summaries.json');
  try {
    await fs.access(summariesPath);
    const content = await fs.readFile(summariesPath, 'utf-8');
    return JSON.parse(content);
  } catch (e) {
    // File not found or corrupted
    return null;
  }
}

/**
 * Loads dependencies for the current project. Returns null if not indexed.
 * @param workingDir The working directory of the project.
 * @returns {Promise<Record<string, string[]> | null>}
 */
export async function loadDependencies(workingDir: string): Promise<Record<string, string[]> | null> {
  const { analysisDir } = await ensureProjectStructure(workingDir);
  const depsPath = path.join(analysisDir, 'dependencies.json');
  try {
    await fs.access(depsPath);
    const content = await fs.readFile(depsPath, 'utf-8');
    return JSON.parse(content);
  } catch (e) {
    // File not found or corrupted
    return null;
  }
}

/**
 * Gets incomplete tasks from the latest run (for re-running).
 * @param workingDir The working directory of the project.
 * @returns {Promise<TaskFile[]>}
 */
export async function getIncompleteTasks(workingDir: string): Promise<TaskFile[]> {
  const { runsDir } = await ensureProjectStructure(workingDir);
  
  let runs: string[] = [];
  try {
    const files = await fs.readdir(runsDir);
    runs = files.sort().reverse();
  } catch (e) {
    return []; // Directory doesn't exist or is inaccessible
  }

  if (runs.length === 0) return [];

  const latestRun = runs[0];
  const tasksDir = path.join(runsDir, latestRun, 'tasks');

  try {
    await fs.access(tasksDir);
  } catch (e) {
    return []; // Tasks directory doesn't exist
  }

  const files = await fs.readdir(tasksDir);
  const taskPromises: Promise<TaskFile>[] = [];

  for (const file of files) {
    const taskPath = path.join(tasksDir, file);
    taskPromises.push((async () => {
      try {
        const content = await fs.readFile(taskPath, 'utf-8');
        const task: TaskFile = JSON.parse(content);
        if (!task.status) {
          return task;
        }
      } catch (e) {
        // Skip corrupted files
        return null;
      }
    })());
  }

  const results = await Promise.all(taskPromises);
  return results.filter((task): task is TaskFile => task !== null);
}