{
  "name": "@bobsworkshop/cli",
  "version": "0.1.3",
  "description": "Bob's CLI — AI coding assistant and Forge orchestrator",
  "type": "module",
  "files": ["dist"],
  "bin": {
    "bob": "./dist/bob.js"
  },
  "scripts": {
    "build": "tsup bin/bob.ts --format esm --out-dir dist",
    "dev": "node --loader ts-node/esm bin/bob.ts",
    "test": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-assistant",
    "workshop",
    "bob",
    "terminal",
    "developer-tools"
  ],
  "author": "Kemone Phillips",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bobsworkshop/bob-cli"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "inquirer": "^14.0.2",
    "marked": "^18.0.4",
    "marked-terminal": "^7.3.0",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "simple-git": "^3.36.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}